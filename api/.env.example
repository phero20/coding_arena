# Database Connections
DATABASE_URL="postgresql://user:pass@host:port/dbname?sslmode=require"
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/dbname"
MONGODB_DB_NAME="coding-arena"

# Shared Infrastructure
REDIS_URL="redis://localhost:6379"
PORT=3000
CLIENT_URL="http://localhost:3000"

# Authentication (Clerk)
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
CLERK_PEM_PUBLIC_KEY="---BEGIN PUBLIC KEY---..." # Required for JWT verification in some environments

# AI Engines (Groq)
GROQ_API_KEY="gsk_..."

# Code Execution (Judge0 - Optional if AI Judge is used exclusively)
JUDGE0_BASE_URL="http://localhost:2358"

# Upstash Redis (Optional fallback)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# Observability
LOG_LEVEL="info" # debug, info, warn, error
